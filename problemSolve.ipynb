      "5\n"
     ]
    }
   ],
   "source": [
    "inp = input()\n",
    "\n",
    "numbers = inp.split()\n",
    "\n",
    "x = int(numbers[0])\n",
    "y = int(numbers[1])\n",
    "\n",
    "\n",
    "lastDigitOfX = x % 10\n",
    "\n",
    "lastDigitOfy = y % 10\n",
    "\n",
    "sum = lastDigitOfX + lastDigitOfy\n",
    "\n",
    "print(sum)"
   ]
  }
